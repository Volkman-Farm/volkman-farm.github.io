# Copy to .env (gitignored). Never commit the real values.
# Setup walkthrough lives in INSTAGRAM-PLAN.md under "Publishing pipeline".
IG_USER_ID=
IG_ACCESS_TOKEN=
# Optional override if Meta retires the default in scripts/ig-publish.mjs
# IG_API_VERSION=v23.0

# Google Photos Picker (scripts/gphotos-pull.mjs): Desktop-app OAuth client
# from console.cloud.google.com with the Photos Picker API enabled.
GPHOTOS_CLIENT_ID=
GPHOTOS_CLIENT_SECRET=
