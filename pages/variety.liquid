---
pagination:
  data: varieties
  size: 1
  alias: variety
permalink: "/greens/{{ variety.slug }}/"
layout: default
eleventyComputed:
  title: "{{ variety.name }} Microgreens"
  description: "{{ variety.name }} microgreens at $3.50/oz, hand-delivered weekly across the Orlando metro. {{ variety.intro }}"
---

<p class="lead">{{ variety.intro }}</p>

<p class="cta-row"><a href="/microgreens/?green={{ variety.slug }}"><strong>Order {{ variety.name | downcase }} →</strong></a> · $3.50/oz</p>

<h2>Flavor</h2>

<p>{{ variety.flavor }}</p>

<h2>Nutrition</h2>

<p>{{ variety.nutrition }}</p>

<h2>How to use {{ variety.name | downcase }} microgreens</h2>

<p>{{ variety.usesLead }}</p>

<ul style="font-family:'Courier New',Courier,monospace;width:min(60ch,92%);margin:16px auto;padding-left:20px;list-style:square">
  {% for use in variety.uses %}
  <li>{{ use }}</li>
  {% endfor %}
</ul>

<h2>How we grow it</h2>

<p>{{ variety.growNote }} We use organic, non-GMO seeds, filtered water, and harvest the morning of delivery. Never refrigerated for days.</p>

<p class="cta-row"><a href="/microgreens/?green={{ variety.slug }}"><strong>Add {{ variety.name | downcase }} to my weekly order →</strong></a></p>

<p style="text-align:center;font-family:Georgia,serif;font-style:italic">Browse all <a href="/greens/">ten varieties</a> or check the <a href="/pricing/">pricing page</a>.</p>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "@id": "https://volkman.farm/greens/{{ variety.slug }}/#product",
  "name": "{{ variety.name }} Microgreens",
  "description": "{{ variety.intro }}",
  "sku": "VF-{{ variety.slug | upcase }}",
  "category": "Food/Produce/Microgreens",
  "mainEntityOfPage": "https://volkman.farm/greens/{{ variety.slug }}/",
  "image": "https://volkman.farm/assets/logo.png",
  "brand": {
    "@type": "Brand",
    "name": "Volkman Farm"
  },
  "additionalProperty": [
    { "@type": "PropertyValue", "name": "Cultivar", "value": "{{ variety.name }}" },
    { "@type": "PropertyValue", "name": "Form", "value": "Microgreen, cut at harvest" },
    { "@type": "PropertyValue", "name": "Seed", "value": "Organic, non-GMO" },
    { "@type": "PropertyValue", "name": "Harvest", "value": "Morning of delivery" }
  ],
  "offers": {
    "@type": "Offer",
    "url": "https://volkman.farm/greens/{{ variety.slug }}/",
    "priceCurrency": "USD",
    "price": "3.50",
    "priceSpecification": {
      "@type": "UnitPriceSpecification",
      "price": "3.50",
      "priceCurrency": "USD",
      "unitText": "ounce"
    },
    "availability": "https://schema.org/InStock",
    "areaServed": [
      {"@type": "City", "name": "Lake Mary"},
      {"@type": "City", "name": "Sanford"},
      {"@type": "City", "name": "Winter Springs"},
      {"@type": "City", "name": "Oviedo"},
      {"@type": "City", "name": "Casselberry"},
      {"@type": "City", "name": "Maitland"},
      {"@type": "City", "name": "Winter Park"},
      {"@type": "Place", "name": "College Park, Orlando"},
      {"@type": "Place", "name": "Downtown Orlando"}
    ],
    "seller": {
      "@type": "LocalBusiness",
      "@id": "https://volkman.farm/#business",
      "name": "Volkman Farm"
    }
  }
}
</script>
